# Copy to .env.local for local development (Vite auto-loads it).
# Where the yem-backend server is reachable. For a physical device or emulator,
# "localhost" won't reach your dev machine — use your machine's LAN IP instead,
# e.g. http://192.168.1.42:4000/api. For production, this is your deployed backend URL.
VITE_API_BASE_URL=http://localhost:4000/api
